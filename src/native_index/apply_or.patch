+static uint32_t *union_sorted(const uint32_t *a,
+                              uint32_t a_count,
+                              const uint32_t *b,
+                              uint32_t b_count,
+                              uint32_t *out_count) {
+    uint32_t max_out = a_count + b_count;
+    uint32_t *out = (uint32_t *)malloc((size_t)max_out * sizeof(uint32_t));
+    if (!out) {
+        *out_count = 0;
+        return NULL;
+    }
+    uint32_t i = 0, j = 0, k = 0;
+    while (i < a_count && j < b_count) {
+        if (a[i] == b[j]) {
+            out[k++] = a[i];
+            i++;
+            j++;
+        } else if (a[i] < b[j]) {
+            out[k++] = a[i++];
+        } else {
+            out[k++] = b[j++];
+        }
+    }
+    while (i < a_count) out[k++] = a[i++];
+    while (j < b_count) out[k++] = b[j++];
+    *out_count = k;
+    return out;
+}
+
+static int apply_filter_ids_or(const cdx1_posting_entry *entries,
+                               const uint32_t *values,
+                               uint32_t entry_count,
+                               const uint32_t *ids,
+                               size_t id_count,
+                               uint32_t **candidate,
+                               uint32_t *candidate_count) {
+    if (id_count == 0) return 0;
+
+    uint32_t *current = NULL;
+    uint32_t current_count = 0;
+
+    for (size_t i = 0; i < id_count; i++) {
+        const uint32_t *vals = NULL;
+        uint32_t count = 0;
+        if (posting_lookup(entries, values, entry_count, ids[i], &vals, &count) && count > 0) {
+            if (current == NULL) {
+                current = (uint32_t *)malloc((size_t)count * sizeof(uint32_t));
+                if (!current) return ENOMEM;
+                memcpy(current, vals, (size_t)count * sizeof(uint32_t));
+                current_count = count;
+            } else {
+                uint32_t out_count = 0;
+                uint32_t *merged = union_sorted(current, current_count, vals, count, &out_count);
+                free(current);
+                if (!merged) return ENOMEM;
+                current = merged;
+                current_count = out_count;
+            }
+        }
+    }
+
+    if (!current) {
+        free(*candidate);
+        *candidate = NULL;
+        *candidate_count = 0;
+        return 0;
+    }
+
+    if (*candidate == NULL) {
+        *candidate = current;
+        *candidate_count = current_count;
+        return 0;
+    }
+
+    uint32_t out_count = 0;
+    uint32_t *merged = intersect_sorted(*candidate, *candidate_count, current, current_count, &out_count);
+    free(*candidate);
+    free(current);
+    if (!merged && out_count > 0) return ENOMEM;
+    *candidate = merged;
+    *candidate_count = out_count;
+    return 0;
+}
